# ==============================
# GOLDBOT — Variables d'environnement
# Copiez ce fichier en .env et remplissez chaque valeur
# NE JAMAIS committer .env dans Git
# ==============================

# --- DeepSeek API ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Telegram ---
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# --- MetaTrader 5 ---
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Demo

# --- Gestion du risque ---
RISK_PERCENT=1.5
MAX_DAILY_DRAWDOWN=3.0
MIN_CONFIDENCE=85
MAX_SIMULTANEOUS_TRADES=2
